# LLM（OpenAI 兼容接口，如 DeepSeek / 火山引擎）
LLM_API_KEY=your_llm_api_key
LLM_API_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Agent LLM（须与 AGENT_LLM_API_URL 匹配；未设置时回落到 LLM_API_KEY）
AGENT_LLM_API_KEY=your_agent_llm_api_key
# AGENT_LLM_API_URL=https://api.deepseek.com
# AGENT_LLM_MODEL=deepseek-chat

# ASR / TTS（SiliconFlow 等）
ASR_TTS_API_KEY=your_asr_tts_api_key

# 可选：TTS 参考音色目录，默认使用项目根目录 ref_audio/
# REF_DIR=d:/aiproj/VocaMind/ref_audio

# 可选：Agent 任务目录与工作目录
# AGENT_TASKS_DIR=d:/aiproj/VocaMind/.tasks
# AGENT_WORKDIR=d:/aiproj/VocaMind

# 可选：文档 HTTP 服务（默认 9002，客户端按 ws 端口 +1 自动推导）
# HTTP_PORT=9002

# 可选：网络搜索（web_search 工具）。未设置时使用 DuckDuckGo（免费、无需 Key）
# TAVILY_API_KEY=your_tavily_api_key
